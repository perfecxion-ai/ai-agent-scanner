# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_agent_scanner
REDIS_URL=redis://localhost:6379/0

# AI API Keys (for testing discovered agents)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# Cloud Provider Credentials
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AZURE_TENANT_ID=your-azure-tenant
AZURE_CLIENT_ID=your-azure-client
AZURE_CLIENT_SECRET=your-azure-secret
GCP_PROJECT_ID=your-gcp-project
GCP_CREDENTIALS_PATH=/path/to/gcp-credentials.json

# Scanning Configuration
MAX_CONCURRENT_SCANS=10
SCAN_TIMEOUT_SECONDS=300
NETWORK_SCAN_THREADS=50

# Security
JWT_SECRET_KEY=your-jwt-secret
ENCRYPTION_KEY=your-32-byte-encryption-key

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your-app-password
